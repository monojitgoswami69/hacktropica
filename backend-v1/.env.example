# =============================================================================
# Backend v1 Configuration
# =============================================================================

# MongoDB Atlas
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/vidyarthi_saarthi?retryWrites=true&w=majority

# Qdrant Vector Database
# Option 1: Local (in-process)
QDRANT_MODE=local
QDRANT_PATH=./qdrant_data

# Option 2: Docker/Server
# QDRANT_MODE=server
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# Option 3: Cloud
# QDRANT_MODE=cloud
# QDRANT_URL=https://xxx.qdrant.io
# QDRANT_API_KEY=your_api_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_QUIZ_MODEL=gemini-2.0-flash-exp

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# Embedding Model
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# HuggingFace (optional, for faster model downloads)
HF_TOKEN=your_hf_token_here

# Text Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
RETRIEVAL_TOP_K=5

# File Storage (Cloudflare R2)
# To enable file preview/download, configure all R2 fields.
# Without these, ingest still works but original files won't be stored.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=vidyarthi-saarthi
# Public bucket URL for preview links (enable via R2 dashboard → Public Access)
# e.g. https://pub-xxxxxxxxxx.r2.dev
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Server
HOST=0.0.0.0
PORT=8001
RELOAD=true

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
